---
exclude_paths:
  - app/assets
  - config
  - db
  - lib/tasks
  - vendor
  - spec
  - node_modules

detectors:
  IrresponsibleModule:
    enabled: false
  UtilityFunction:
    enabled: false
  ControlParameter:
    enabled: false
  BooleanParameter:
    enabled: false
  FeatureEnvy:
    enabled: false
  TooManyStatements:
    max_statements: 10
  TooManyMethods:
    max_methods: 25
  UncommunicativeVariableName:
    accept:
      - e
