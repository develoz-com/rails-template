# frozen_string_literal: true

require "spec_helper"
require_relative "../config/environment"
require "rspec/rails"
require "socket"
require "factory_bot"
require "capybara/rspec"
require "selenium-webdriver"

Dir[Rails.root.join("spec/support/**/*.rb")].sort.each { |f| require f }

RSpec.configure do |config|
  config.fixture_paths = [ "#{::Rails.root}/spec/fixtures" ]
  config.use_transactional_fixtures = true
  config.infer_spec_type_from_file_location!
  config.filter_rails_from_backtrace!

  # System specs run under the fast rack_test driver by default. Set
  # SCREENSHOTS=true (used by bin/generate-docs) or tag an example with
  # `:js` to drive a real headless Chromium session instead.
  config.before(type: :system) { driven_by ENV["SCREENSHOTS"] == "true" ? :headless_chrome : :rack_test }
  config.before(type: :system, js: true) { driven_by :headless_chrome }
end

# When SELENIUM_URL is set (Docker Compose ships a selenium/standalone-chromium
# service) the browser runs in a sibling container and reaches the Rails test
# server by this container's hostname on a parallel-safe port. Otherwise Capybara
# launches a local Chromium via selenium-webdriver.
selenium_url = ENV["SELENIUM_URL"].to_s

Capybara.register_driver :headless_chrome do |app|
  options = Selenium::WebDriver::Chrome::Options.new
  options.add_argument("--headless=new")
  options.add_argument("--no-sandbox")
  options.add_argument("--disable-gpu")
  options.add_argument("--disable-dev-shm-usage")
  options.add_argument("--window-size=1400,1400")

  http_client = Selenium::WebDriver::Remote::Http::Default.new
  http_client.read_timeout = 120
  http_client.open_timeout = 120

  if selenium_url.empty?
    Capybara::Selenium::Driver.new(app, browser: :chrome, options: options, http_client: http_client)
  else
    Capybara::Selenium::Driver.new(app, browser: :remote, url: selenium_url, options: options, http_client: http_client)
  end
end

Capybara.javascript_driver = :headless_chrome

unless selenium_url.empty?
  Capybara.server_host = "0.0.0.0"
  Capybara.server_port = ENV.fetch("CAPYBARA_SERVER_PORT", "45678").to_i + ENV.fetch("TEST_ENV_NUMBER", "0").to_i
  Capybara.app_host = "http://#{Socket.gethostname}:#{Capybara.server_port}"
end

FactoryBot.definition_file_paths = [ File.expand_path("factories", __dir__) ]
FactoryBot.find_definitions

ActiveRecord::Migration.maintain_test_schema!
